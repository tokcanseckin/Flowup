# FlowUp Frontend — environment variables
# Copy to .env and fill in your values.

# Google OAuth client ID (from console.cloud.google.com → APIs & Services → Credentials)
# Create an OAuth 2.0 Client ID of type "Web application".
# Add your frontend origin (e.g. http://127.0.0.1:5173) to Authorised JavaScript origins.
VITE_GOOGLE_CLIENT_ID=

# Spotify app client ID (from developer.spotify.com)
# Register http://127.0.0.1:5173 as a redirect URI in your Spotify app settings.
VITE_SPOTIFY_CLIENT_ID=your_spotify_client_id_here

# Spotify requirement: localhost is not allowed. Use explicit loopback or HTTPS.
VITE_SPOTIFY_REDIRECT_URI=http://127.0.0.1:5173
