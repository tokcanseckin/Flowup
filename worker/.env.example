# FlowUp Alignment Worker — configuration
# Copy this file to .env and fill in the values:
#   cp .env.example .env

# ── Required ───────────────────────────────────────────────────────────────────

# URL of the remote FlowUp backend (no trailing slash)
REMOTE_API_URL=https://your-server.example.com

# Shared secret that authenticates this worker to the backend.
# Generate one with:  python3 -c "import secrets; print(secrets.token_hex(32))"
# Set the same value as WORKER_API_KEY in the backend .env
WORKER_API_KEY=

# ── Optional ───────────────────────────────────────────────────────────────────

# How often to poll for new tasks (seconds). Default: 30
POLL_INTERVAL=30

# Whisper model used by stable-ts for forced alignment.
# large-v3-turbo is fast and accurate on Apple Silicon.
# Options: tiny, base, small, medium, large-v2, large-v3, large-v3-turbo
STABLE_TS_MODEL=large-v3-turbo

# Path to a Netscape-format cookies file for yt-dlp.
# Useful when YouTube rate-limits anonymous requests.
# Export from your browser with the "Get cookies.txt LOCALLY" extension.
# YOUTUBE_COOKIES_FILE=/Users/you/youtube-cookies.txt
