# FlowUp Backend — environment variables
# Copy to .env and fill in your values.

# Spotify app client ID (from developer.spotify.com)
SPOTIFY_CLIENT_ID="9f885c355e504c14aa13a5e1903d48bd"

# Google OAuth client ID (from console.cloud.google.com → APIs & Services → Credentials)
# Create an OAuth 2.0 Client ID of type "Web application".
# Add your frontend origin (e.g. http://127.0.0.1:5173) to Authorised JavaScript origins.
GOOGLE_CLIENT_ID=203072210352-6vidcd2pppcgeb3i0lom5qir8bk2ocvj.apps.googleusercontent.com

# SQLite database path (relative to backend/ directory)
DATABASE_URL=sqlite:///./flowup.db

# DeepL API key (optional — used for translation enrichment)
DEEPL_API_KEY=

# Shared secret for the alignment worker.
# Generate one with: python3 -c "import secrets; print(secrets.token_hex(32))"
# Set the same value as WORKER_API_KEY in worker/.env
WORKER_API_KEY=

# Path to a Netscape-format YouTube cookies file for yt-dlp.
# Required on server IPs that YouTube blocks as bots.
# Export from Chrome/Firefox with the "Get cookies.txt LOCALLY" extension.
YOUTUBE_COOKIES_FILE=

# Apple Music / MusicKit credentials (from developer.apple.com)
# Required to enable Apple Music playback.
# Create a MusicKit key in Certificates, Identifiers & Profiles → Keys.
APPLE_MUSIC_TEAM_ID=
APPLE_MUSIC_KEY_ID=
# Paste the full PEM content of the .p8 file; use \n for line breaks in .env
APPLE_MUSIC_PRIVATE_KEY=

# Admin bootstrap user (created on backend startup if missing)
FLOWUP_ADMIN_EMAIL=admin@flowup.local
FLOWUP_ADMIN_PASSWORD=flowup-admin
FLOWUP_ADMIN_SPOTIFY_ID=admin:local
