# FlowUp Backend — environment variables
# Copy to .env and fill in your values.

# Spotify app client ID (from developer.spotify.com)
SPOTIFY_CLIENT_ID="9f885c355e504c14aa13a5e1903d48bd"

# SQLite database path (relative to backend/ directory)
DATABASE_URL=sqlite:///./flowup.db

# DeepL API key (optional — used for translation enrichment)
DEEPL_API_KEY=

# Apple Music / MusicKit credentials (from developer.apple.com)
# Required to enable Apple Music playback.
# Create a MusicKit key in Certificates, Identifiers & Profiles → Keys.
APPLE_MUSIC_TEAM_ID=
APPLE_MUSIC_KEY_ID=
# Paste the full PEM content of the .p8 file; use \n for line breaks in .env
APPLE_MUSIC_PRIVATE_KEY=

# Admin bootstrap user (created on backend startup if missing)
FLOWUP_ADMIN_EMAIL=admin@flowup.local
FLOWUP_ADMIN_PASSWORD=flowup-admin
FLOWUP_ADMIN_SPOTIFY_ID=admin:local
